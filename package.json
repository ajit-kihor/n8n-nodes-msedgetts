{
  "name": "n8n-nodes-msedgetts",
  "version": "1.0.0",
  "description": "Microsoft Edge TTS node for n8n",
  "main": "dist/nodes/MsEdgeTts/MsEdgeTts.node.js",
  "scripts": {
    "build": "tsc && gulp",
    "lint": "eslint \"{nodes,utils,test}/**/*.ts\"",
    "format": "prettier --write \"{nodes,utils,test}/**/*.ts\" \"**/*.json\" \"**/*.md\"",
    "test": "jest"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "text-to-speech",
    "tts",
    "edge-tts",
    "microsoft-edge",
    "audio",
    "automation"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nikhil/n8n-nodes-msedgetts.git"
  },
  "author": "Nikhil",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nikhil/n8n-nodes-msedgetts/issues"
  },
  "homepage": "https://github.com/nikhil/n8n-nodes-msedgetts#readme",
  "engines": {
    "node": ">=18"
  },
  "n8n": {
